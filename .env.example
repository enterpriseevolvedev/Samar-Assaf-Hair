# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where bridal enquiries are delivered (the salon inbox)
ENQUIRY_TO=hello@samarassafhair.com.au

# Verified sending address on your Resend domain.
# Must be on a domain you've verified in Resend, e.g. "Samar Assaf Hair <enquiries@samarassafhair.com.au>"
ENQUIRY_FROM=

# Public contact email shown to brides in the page's left panel (NOT a secret).
# Falls back to hello@samarassafhair.com.au if unset.
NEXT_PUBLIC_CONTACT_EMAIL=hello@samarassafhair.com.au
